# Zerobus producer config — copy to src/ingest/.env and fill in. Runs OFF-platform.
# The producer streams synthetic energy-fleet telemetry into the bronze Delta table.

# Zerobus gRPC endpoint for your workspace (Settings → check region):
#   <workspace-id>.zerobus.<region>.cloud.databricks.com
ZEROBUS_SERVER_ENDPOINT=

# Workspace URL (https://<host>) and the bronze landing table.
DATABRICKS_WORKSPACE_URL=
ZEROBUS_TABLE_NAME=lakebase_sink_demo.ops.bronze_sensor_reading

# M2M service principal with USE CATALOG/SCHEMA + SELECT + MODIFY on the bronze table.
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Tuning (optional)
EMIT_INTERVAL_SECONDS=1.0
SPIKE_PROBABILITY=0.02
BAD_QUALITY_PROBABILITY=0.01
